# Backend Service
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=querywise
DB_PASSWORD=your_password_here
DB_NAME=querywise

# Backend Configuration
LOG_LEVEL=info
API_SECRET=your_api_secret_here

# Set to false to disable Google auth and allow unauthenticated access (for testing only)
# ENABLE_GOOGLE_AUTH=false

# Google OAuth 2 (SSO) — create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI for OAuth: http://localhost:3000/api/v1/auth/google/callback (dev) or your BACKEND_URL/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs (for OAuth redirects; no trailing slash)
FRONTEND_URL=http://localhost:3001
# Optional extra CORS origins (comma-separated, no spaces required)
# FRONTEND_URLS=https://app.example.com,https://staging.example.com
ENABLE_GOOGLE_AUTH=false

# BACKEND_URL defaults to http://localhost:PORT

# JWT for session (defaults to API_SECRET if unset)
# JWT_SECRET=your_jwt_secret_here
